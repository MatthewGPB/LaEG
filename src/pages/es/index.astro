---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SignatureCarousel from '../../components/SignatureCarousel.astro';
import DeliveryOptions from '../../components/DeliveryOptions.astro';
import SmartImage from '../../components/SmartImage.astro';
import site from '../../data/site.json';
import menu from '../../data/menu.json';
import es from '../../data/menu-es.json';

const esSpecials: Record<string, any> = es.weeklySpecials;

const description = "Restaurante guatemalteco familiar en Jupiter, FL. Tacos caseros auténticos, La Parrillada, Pepián, empanadas y especiales semanales de $10. Comedor, para llevar, entrega por DoorDash y Uber Eats, catering y el food truck Guatamigos.";

const alternates = [
  { hreflang: 'en', href: site.domain + '/' },
  { hreflang: 'es', href: site.domain + '/es/' },
  { hreflang: 'x-default', href: site.domain + '/' },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Restaurant',
  '@id': site.domain + '/#restaurant',
  name: site.name,
  description: description,
  url: site.domain + '/es/',
  inLanguage: 'es',
  telephone: site.phoneTel,
  servesCuisine: ['Guatemalan', 'Latin American', 'Central American'],
  priceRange: '$$',
  hasMenu: site.domain + '/es/menu',
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.address.street,
    addressLocality: site.address.city,
    addressRegion: site.address.region,
    postalCode: site.address.postalCode,
    addressCountry: site.address.country,
  },
  geo: { '@type': 'GeoCoordinates', latitude: site.address.lat, longitude: site.address.lng },
  image: site.domain + '/LAEG/hero-mural.jpeg',
  sameAs: [site.social.instagram, site.social.facebook],
};
---

<BaseLayout
  title={`${site.name} — Comida Guatemalteca Auténtica en Jupiter, FL`}
  description={description}
  path="/es/"
  image="/LAEG/hero-mural.jpeg"
  schema={schema}
  showPopup={true}
  lang="es"
  alternates={alternates}
>
  <!-- HERO -->
  <section class="relative isolate overflow-hidden">
    <div class="absolute inset-0 -z-10">
      <SmartImage
        src="/LAEG/hero-mural.jpeg"
        alt="Restaurante guatemalteco auténtico en Jupiter, Florida"
        class="h-full w-full object-cover"
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-gradient-to-br from-navy/85 via-navy/65 to-navy/85"></div>
    </div>

    <div class="container-x relative py-24 lg:py-36">
      <div class="max-w-3xl">
        <p class="eyebrow text-marigold">Jupiter, FL · Negocio familiar desde 2018</p>
        <h1 class="mt-4 text-balance font-display text-5xl font-bold leading-[1.05] text-cream md:text-7xl">
          Comida Guatemalteca Auténtica
          <span class="italic text-marigold">en Jupiter, FL</span>
        </h1>
        <p class="mt-7 max-w-2xl text-pretty font-body text-lg leading-relaxed text-cream/85 md:text-xl">
          <span class="italic text-cream/95">La cocina de la familia</span> — sabores guatemaltecos
          caseros hechos frescos cada día. Tacos, La Parrillada, Pepián y la cálida bienvenida
          de una verdadera cocina familiar. Aquí mismo, en Hibiscus St.
        </p>
        <div class="mt-10 flex flex-wrap gap-4">
          <a href={site.orderUrl} target="_blank" rel="noopener" class="btn-spice text-base">
            Ordenar en línea
          </a>
          <a href="#delivery" class="rounded-full border-2 border-cream/40 bg-cream/10 px-7 py-3 font-body font-semibold text-cream backdrop-blur-sm transition-colors hover:bg-cream hover:text-navy">
            Pídelo a domicilio
          </a>
        </div>

        <div class="mt-12 flex flex-wrap items-center gap-x-8 gap-y-3 text-sm text-cream/75">
          <span class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-marigold"></span> Abierto lun–dom 11am–9pm</span>
          <span class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-marigold"></span> Comedor · Para llevar · Entrega · Catering</span>
          <span class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-marigold"></span> {site.phone}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- TRES OFERTAS -->
  <section class="container-x -mt-12 grid gap-5 md:grid-cols-3 lg:-mt-16">
    <a href="/es/menu" class="group relative overflow-hidden rounded-3xl bg-white p-7 shadow-card transition-transform hover:-translate-y-1">
      <div class="absolute right-0 top-0 h-24 w-24 rounded-bl-full bg-marigold/20 transition-colors group-hover:bg-marigold/40"></div>
      <p class="eyebrow relative">El Menú</p>
      <h3 class="relative mt-2 font-display text-2xl font-bold text-navy">Comedor y para llevar</h3>
      <p class="relative mt-3 font-body text-ink/70">Menú completo, especiales semanales de $10 y tortillas hechas a mano todos los días.</p>
      <span class="relative mt-5 inline-flex items-center gap-2 font-semibold text-spice">Explorar menú →</span>
    </a>

    <a href="/es/catering" class="group relative overflow-hidden rounded-3xl bg-white p-7 shadow-card transition-transform hover:-translate-y-1">
      <div class="absolute right-0 top-0 h-24 w-24 rounded-bl-full bg-spice/15 transition-colors group-hover:bg-spice/30"></div>
      <p class="eyebrow relative">Catering</p>
      <h3 class="relative mt-2 font-display text-2xl font-bold text-navy">Para tu celebración</h3>
      <p class="relative mt-3 font-body text-ink/70">Clubes, bodas, eventos corporativos. Menús a la medida, servidos con profesionalismo.</p>
      <span class="relative mt-5 inline-flex items-center gap-2 font-semibold text-spice">Pedir cotización →</span>
    </a>

    <a href="/es/food-truck" class="group relative overflow-hidden rounded-3xl bg-white p-7 shadow-card transition-transform hover:-translate-y-1">
      <div class="absolute right-0 top-0 h-24 w-24 rounded-bl-full bg-navy/10 transition-colors group-hover:bg-navy/25"></div>
      <p class="eyebrow relative">Guatamigos</p>
      <h3 class="relative mt-2 font-display text-2xl font-bold text-navy">El food truck</h3>
      <p class="relative mt-3 font-body text-ink/70">Nuestra cocina móvil llega a eventos privados por todo Palm Beach County.</p>
      <span class="relative mt-5 inline-flex items-center gap-2 font-semibold text-spice">Reservar el truck →</span>
    </a>
  </section>

  <!-- OPCIONES DE ENTREGA -->
  <DeliveryOptions lang="es" />

  <!-- CARRUSEL DE PLATILLOS -->
  <SignatureCarousel lang="es" />

  <!-- HISTORIA -->
  <section class="bg-navy/95 py-20 text-cream lg:py-28">
    <div class="container-x grid items-center gap-12 lg:grid-cols-2">
      <div class="overflow-hidden rounded-3xl shadow-deep">
        <SmartImage
          src="/LAEG/family.jpeg"
          alt="La familia Cano en La Esquina Guatemalteca"
          class="aspect-[4/5] w-full object-cover"
        />
      </div>
      <div>
        <p class="eyebrow text-marigold">Nuestra Historia</p>
        <h2 class="mt-3 text-balance font-display text-4xl font-bold md:text-5xl">
          Un sueño con raíces en Huehuetenango.
        </h2>
        <p class="mt-6 text-pretty font-body text-lg leading-relaxed text-cream/85">
          Silvia Cano aprendió a cocinar en la cocina familiar de su suegra — sin recetas escritas,
          solo el toque perfecto. Cuando ella y Santos se mudaron a Jupiter con sus hijos, Guatemala
          vino con ellos a través de la comida. Hoy toda la familia atiende esta esquina.
        </p>
        <blockquote class="mt-7 border-l-4 border-marigold pl-5 font-display text-xl italic text-cream/95">
          "Muy feliz" — así me siento todos los días en esta cocina.
          <footer class="mt-2 font-body text-sm not-italic text-cream/70">— Silvia Cano, Propietaria y Chef</footer>
        </blockquote>
        <a href="/es/about" class="btn-secondary mt-8 border-cream text-cream hover:bg-cream hover:text-navy">
          Lee nuestra historia completa
        </a>
      </div>
    </div>
  </section>

  <!-- ESPECIALES SEMANALES -->
  <section class="container-x py-20 lg:py-24">
    <div class="mx-auto max-w-2xl text-center">
      <p class="eyebrow">Especiales semanales de $10</p>
      <h2 class="mt-3 text-balance font-display text-4xl font-bold text-navy md:text-5xl">
        Un favorito diferente, cada día.
      </h2>
      <p class="mt-5 text-pretty font-body text-lg leading-relaxed text-ink/75">
        Rápido, delicioso y a buen precio — perfecto para estudiantes, familias con prisa,
        o cualquiera que antoje auténtico sabor guatemalteco.
      </p>
    </div>

    <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {menu.weeklySpecials.map((special) => (
        <article class="overflow-hidden rounded-3xl bg-white shadow-card transition-transform hover:-translate-y-1">
          <SmartImage src={special.image} alt={esSpecials[special.name]?.name || special.name} class="h-52 w-full object-cover" />
          <div class="p-6">
            <h3 class="font-display text-xl font-bold text-navy">{esSpecials[special.name]?.name || special.name}</h3>
            <p class="mt-2 font-body text-sm leading-relaxed text-ink/70">{esSpecials[special.name]?.description || special.description}</p>
            <p class="mt-4 font-display text-2xl font-bold text-price">{special.price}</p>
          </div>
        </article>
      ))}
    </div>

    <div class="mt-12 text-center">
      <a href="/es/menu" class="btn-primary">Ver el menú completo</a>
    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="bg-gradient-to-br from-navy via-navy-600 to-navy py-20 text-cream lg:py-24">
    <div class="container-x mx-auto max-w-3xl text-center">
      <h2 class="text-balance font-display text-4xl font-bold md:text-5xl">
        ¿Con hambre? <span class="text-marigold">Estamos a la vuelta de la esquina.</span>
      </h2>
      <p class="mt-5 font-body text-lg text-cream/85">
        Comida guatemalteca auténtica, fresca y caliente — en el comedor, para llevar o a domicilio.
      </p>
      <div class="mt-9 flex flex-wrap justify-center gap-4">
        <a href={site.orderUrl} target="_blank" rel="noopener" class="btn-spice">Ordenar para llevar</a>
        <a href={`tel:${site.phoneTel}`} class="btn-secondary border-cream text-cream hover:bg-cream hover:text-navy">
          Llama al {site.phone}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
