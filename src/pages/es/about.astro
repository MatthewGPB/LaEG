---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SmartImage from '../../components/SmartImage.astro';
import site from '../../data/site.json';

const description = "Conoce a la familia Cano detrás de La Esquina Guatemalteca. De Huehuetenango, Guatemala a Jupiter, FL — Silvia, Santos, William y la familia comparten su historia de auténtica cocina guatemalteca casera desde 2018.";

const alternates = [
  { hreflang: 'en', href: site.domain + '/about' },
  { hreflang: 'es', href: site.domain + '/es/about' },
  { hreflang: 'x-default', href: site.domain + '/about' },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Restaurant',
  '@id': site.domain + '/#restaurant',
  name: site.name,
  description: description,
  url: site.domain + '/es/about',
  inLanguage: 'es',
  telephone: site.phoneTel,
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.address.street,
    addressLocality: site.address.city,
    addressRegion: site.address.region,
    postalCode: site.address.postalCode,
    addressCountry: site.address.country,
  },
  founder: { '@type': 'Person', name: site.founder },
  foundingDate: site.founded,
  image: site.domain + '/LAEG/family.jpeg',
  sameAs: [site.social.instagram, site.social.facebook],
};
---

<BaseLayout
  title="Nuestra Historia — De Huehuetenango a Jupiter"
  description={description}
  path="/es/about"
  image="/LAEG/family.jpeg"
  schema={schema}
  lang="es"
  alternates={alternates}
>
  <!-- HERO -->
  <section class="relative isolate overflow-hidden">
    <div class="absolute inset-0 -z-10">
      <SmartImage
        src="/LAEG/hero-mural.jpeg"
        alt="Restaurante guatemalteco auténtico en Jupiter, Florida"
        class="h-full w-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-navy/60 via-navy/40 to-navy/85"></div>
    </div>
    <div class="container-x relative py-28 text-center text-cream lg:py-36">
      <p class="eyebrow text-marigold">Nuestra Historia</p>
      <h1 class="mx-auto mt-4 max-w-3xl text-balance font-display text-5xl font-bold leading-tight md:text-7xl">
        Restaurante Guatemalteco Familiar <span class="italic text-marigold">en Jupiter, FL</span>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-pretty font-body text-lg leading-relaxed text-cream/85 md:text-xl">
        Un sueño familiar, traído de Guatemala al corazón de Jupiter.
      </p>
    </div>
  </section>

  <!-- BIENVENIDA -->
  <section class="container-x py-20 text-center lg:py-24">
    <h2 class="mx-auto max-w-3xl text-balance font-display text-4xl font-bold text-navy md:text-5xl">
      Bienvenidos a La Esquina Guatemalteca
    </h2>
    <p class="mx-auto mt-6 max-w-3xl text-pretty font-body text-lg leading-relaxed text-ink/80 md:text-xl">
      La Esquina Guatemalteca es mucho más que un restaurante. Es la manera en que nuestra familia
      comparte los sabores auténticos, las tradiciones y el calor de Guatemala aquí en Jupiter.
      Abrimos en diciembre de 2018, cumpliendo el sueño de toda una vida: traer los sabores
      guatemaltecos caseros a nuestra comunidad y crear un lugar que se sienta como el hogar
      para todo el que entre por la puerta.
    </p>
  </section>

  <!-- HISTORIA FAMILIAR -->
  <section class="bg-cream-200/50 py-20 lg:py-24">
    <div class="container-x grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
      <div class="overflow-hidden rounded-3xl shadow-deep">
        <SmartImage
          src="/LAEG/family.jpeg"
          alt="La familia Cano en La Esquina Guatemalteca Jupiter"
          class="aspect-[4/5] w-full object-cover"
        />
      </div>
      <div>
        <p class="eyebrow">Huehuetenango → Jupiter</p>
        <h2 class="mt-3 text-balance font-display text-4xl font-bold text-navy md:text-5xl">
          Un sueño con raíces en Huehuetenango
        </h2>
        <div class="mt-6 space-y-5 font-body text-base leading-relaxed text-ink/80 md:text-lg">
          <p>
            Soy Silvia Cano, originaria de Huehuetenango, Guatemala. Aprendí a cocinar en el
            restaurante familiar de la mamá de mi esposo Santos — cada platillo hecho con amor
            e intuición, sin recetas escritas, solo el toque perfecto. Cuando nos mudamos a Jupiter
            con nuestros hijos, Santos Cano Vásquez y William Cano, Guatemala vino con nosotros
            a través de la cocina.
          </p>
          <p>
            Como contó el Palm Beach Post en 2019, nuestros muchachos quizás no recuerdan mucho
            de la tierra — eran niños cuando llegamos — pero siempre la han saboreado en la comida
            que preparo. "Todo está en su toque," dice William. Y Santos agrega: "Me llena de
            felicidad ver mis dos mundos unirse."
          </p>
          <p>
            Abrir La Esquina Guatemalteca fue mi manera de compartir esa alegría: platillos
            auténticos como nuestro famoso churrasco, las enchiladas guatemaltecas únicas,
            caldos abundantes y rellenitos dulces — todo hecho fresco cada día con el mismo
            amor de familia.
          </p>
        </div>

        <blockquote class="mt-8 border-l-4 border-marigold pl-6 font-display text-2xl italic text-navy">
          "Muy feliz" — así me siento todos los días en esta cocina.
          <footer class="mt-3 font-body text-sm not-italic text-ink/65">— Silvia Cano</footer>
        </blockquote>

        <p class="mt-7 font-body text-base leading-relaxed text-ink/80 md:text-lg">
          Hoy, toda nuestra familia atiende este lugar: Santos y yo en el corazón de la cocina,
          con nuestros hijos ayudando en el comedor. Nos enorgullece servir a vecinos, familias,
          visitantes y estudiantes por igual — creando una esquina acogedora donde todos se
          sienten en casa.
        </p>
      </div>
    </div>
  </section>

  <!-- LO QUE NOS HACE ESPECIALES -->
  <section class="container-x py-20 text-center lg:py-24">
    <div class="mx-auto max-w-3xl">
      <p class="eyebrow">Lo que nos hace especiales</p>
      <h2 class="mt-3 text-balance font-display text-4xl font-bold text-navy md:text-5xl">
        Guatemalteco de verdad.
      </h2>
      <p class="mt-6 text-pretty font-body text-lg leading-relaxed text-ink/80">
        Celebramos lo que distingue a la cocina guatemalteca — tortillas más gruesas, frijol negro,
        aguas frescas de rosa de Jamaica, atole en taza de barro y nuestra insignia: La Parrillada.
        Todo es casero, con raíces en la tradición y servido con el calor de la familia.
      </p>
      <p class="mt-4 text-pretty font-body text-lg leading-relaxed text-ink/80">
        Y seguimos creciendo para traerte más: comedor ampliado con nuestro nuevo bar de cócteles,
        catering de alto nivel y nuestro food truck Guatamigos listo para cualquier celebración.
      </p>
    </div>

    <div class="mt-12 flex flex-wrap justify-center gap-4">
      <a href={site.directionsUrl} target="_blank" rel="noopener" class="btn-primary">Visítanos</a>
      <a href="/es/catering" class="btn-secondary">Descubre el catering</a>
    </div>
  </section>

  <!-- CIFRAS -->
  <section class="bg-navy py-16 text-cream lg:py-20">
    <div class="container-x grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
      <div>
        <p class="font-display text-4xl font-bold text-marigold">7+</p>
        <p class="mt-2 font-body text-cream/85">Años sirviendo a Jupiter</p>
      </div>
      <div>
        <p class="font-display text-4xl font-bold text-marigold">100%</p>
        <p class="mt-2 font-body text-cream/85">Familiar, de principio a fin</p>
      </div>
      <div>
        <p class="font-display text-4xl font-bold text-marigold">Diario</p>
        <p class="mt-2 font-body text-cream/85">Tortillas frescas hechas a mano</p>
      </div>
      <div>
        <p class="font-display text-4xl font-bold text-marigold">5+</p>
        <p class="mt-2 font-body text-cream/85">Clubes de prestigio donde damos catering</p>
      </div>
    </div>
  </section>

  <!-- CIERRE -->
  <section class="container-x py-20 text-center lg:py-24">
    <p class="mx-auto max-w-2xl text-pretty font-body text-xl leading-relaxed text-ink/80">
      Ya sea que antojes sabores auténticos, una comida en familia o catering para tu próximo
      evento, aquí te esperamos con los brazos abiertos.
    </p>
    <p class="mt-4 font-body text-lg text-ink/70">
      Visítanos en 200 Hibiscus St, Jupiter, FL 33458 — tu esquina guatemalteca te espera.
    </p>
    <div class="mt-9 flex flex-wrap justify-center gap-4">
      <a href="/es/location" class="btn-primary">Ubicación y horario</a>
      <a href="/es/menu" class="btn-secondary">Ver el menú</a>
    </div>
  </section>
</BaseLayout>
