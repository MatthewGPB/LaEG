---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FoodTruckForm from '../../components/FoodTruckForm.astro';
import SmartImage from '../../components/SmartImage.astro';
import site from '../../data/site.json';
import eventsData from '../../data/events.json';

const description = "Reserva el food truck Guatamigos para tu evento en Palm Beach County. Auténtica comida callejera guatemalteca — tacos, empanadas y más — directo a tu boda, evento corporativo o fiesta.";

const alternates = [
  { hreflang: 'en', href: site.domain + '/food-truck' },
  { hreflang: 'es', href: site.domain + '/es/food-truck' },
  { hreflang: 'x-default', href: site.domain + '/food-truck' },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'FoodEstablishment',
  name: 'Guatamigos Food Truck',
  parentOrganization: { '@type': 'Restaurant', name: site.name },
  servesCuisine: 'Guatemalan',
  url: site.domain + '/es/food-truck',
  inLanguage: 'es',
  telephone: site.phoneTel,
  areaServed: site.areaServed.map((a) => ({ '@type': 'City', name: a })),
};
---

<BaseLayout
  title="Food Truck Guatamigos — Resérvalo para tu Evento"
  description={description}
  path="/es/food-truck"
  image="/LAEG/food-truck.jpeg"
  schema={schema}
  lang="es"
  alternates={alternates}
>
  <!-- HERO -->
  <section class="relative isolate overflow-hidden">
    <div class="absolute inset-0 -z-10">
      <SmartImage
        src="/LAEG/food-truck.jpeg"
        alt="Food truck guatemalteco Guatamigos en Palm Beach County"
        class="h-full w-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-navy/70 via-navy/50 to-navy/90"></div>
    </div>
    <div class="container-x relative py-28 text-center text-cream lg:py-36">
      <p class="eyebrow text-marigold">Guatamigos — Nuestro Food Truck</p>
      <h1 class="mx-auto mt-4 max-w-3xl text-balance font-display text-5xl font-bold leading-tight md:text-6xl">
        La fiesta <span class="italic text-marigold">llega a ti.</span>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-pretty font-body text-lg text-cream/85 md:text-xl">
        Auténtica comida callejera guatemalteca, directo a tu boda, oficina o fiesta
        en el patio — en cualquier punto de Palm Beach County.
      </p>
      <div class="mt-9 flex flex-wrap justify-center gap-4">
        <a href="#book" class="btn-spice">Reservar el truck</a>
        <a href={site.social.guatamigosInstagram} target="_blank" rel="noopener" class="rounded-full border-2 border-cream/40 bg-cream/10 px-7 py-3 font-body font-semibold text-cream backdrop-blur-sm transition-colors hover:bg-cream hover:text-navy">
          Sigue a {site.social.guatamigosHandle}
        </a>
      </div>
    </div>
  </section>

  <!-- PRÓXIMAS PARADAS -->
  <section class="container-x py-20 lg:py-24">
    <div class="mx-auto max-w-2xl text-center">
      <p class="eyebrow">Dónde estaremos</p>
      <h2 class="mt-3 text-balance font-display text-4xl font-bold text-navy md:text-5xl">
        Próximas paradas
      </h2>
      <p class="mt-4 font-body text-lg text-ink/75">
        Sigue a <a href={site.social.guatamigosInstagram} target="_blank" rel="noopener" class="font-semibold text-spice hover:underline">{site.social.guatamigosHandle}</a> en Instagram para ubicaciones y pop-ups en tiempo real.
      </p>
    </div>

    <div class="mx-auto mt-12 max-w-2xl space-y-4">
      {eventsData.events.map((event) => (
        <div class="flex flex-wrap items-center justify-between gap-4 rounded-2xl bg-white p-6 shadow-soft">
          <div>
            <h3 class="font-display text-lg font-bold text-navy">{event.title}</h3>
            <p class="font-body text-sm text-ink/65">{event.type} · {event.menu}</p>
          </div>
          <span class="rounded-full bg-marigold/20 px-4 py-1.5 font-body text-sm font-semibold text-marigold-dark">
            {event.date}
          </span>
        </div>
      ))}
    </div>
  </section>

  <!-- FORMULARIO -->
  <section id="book" class="scroll-mt-24 bg-cream-200/50 py-20 lg:py-24">
    <div class="container-x">
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow">Eventos privados</p>
        <h2 class="mt-3 text-balance font-display text-4xl font-bold text-navy md:text-5xl">
          Reserva Guatamigos para tu evento
        </h2>
        <p class="mt-4 font-body text-lg text-ink/75">
          Bodas, almuerzos corporativos, cumpleaños, fiestas de vecinos — si hay gente reunida,
          la alimentamos bien.
        </p>
      </div>
      <div class="mt-12">
        <FoodTruckForm lang="es" />
      </div>
    </div>
  </section>
</BaseLayout>
