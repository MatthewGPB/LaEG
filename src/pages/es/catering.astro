---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CateringForm from '../../components/CateringForm.astro';
import SmartImage from '../../components/SmartImage.astro';
import site from '../../data/site.json';

const description = "Catering guatemalteco en Palm Beach County. Con la confianza de Frenchman's Reserve, Jupiter Hills Club, Avenir, Mirasol y Breakers West. Menús a la medida para bodas, eventos corporativos y celebraciones privadas.";

const alternates = [
  { hreflang: 'en', href: site.domain + '/catering' },
  { hreflang: 'es', href: site.domain + '/es/catering' },
  { hreflang: 'x-default', href: site.domain + '/catering' },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'FoodEstablishment',
  name: `${site.name} Catering`,
  servesCuisine: 'Guatemalan',
  url: site.domain + '/es/catering',
  inLanguage: 'es',
  telephone: site.phoneTel,
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.address.street,
    addressLocality: site.address.city,
    addressRegion: site.address.region,
    postalCode: site.address.postalCode,
    addressCountry: site.address.country,
  },
  areaServed: site.areaServed.map((a) => ({ '@type': 'City', name: a })),
};
---

<BaseLayout
  title="Catering — Bodas, Eventos Corporativos y Privados"
  description={description}
  path="/es/catering"
  image="/LAEG/catering-spread.jpeg"
  schema={schema}
  lang="es"
  alternates={alternates}
>
  <!-- HERO -->
  <section class="relative isolate overflow-hidden">
    <div class="absolute inset-0 -z-10">
      <SmartImage
        src="/LAEG/catering-spread.jpeg"
        alt="Banquete de catering guatemalteco de La Esquina Guatemalteca"
        class="h-full w-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-navy/70 via-navy/50 to-navy/90"></div>
    </div>
    <div class="container-x relative py-28 text-center text-cream lg:py-36">
      <p class="eyebrow text-marigold">Catering por La Esquina</p>
      <h1 class="mx-auto mt-4 max-w-3xl text-balance font-display text-5xl font-bold leading-tight md:text-6xl">
        Sabores de los que tus invitados <span class="italic text-marigold">seguirán hablando.</span>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-pretty font-body text-lg text-cream/85 md:text-xl">
        Catering guatemalteco auténtico para bodas, eventos corporativos y celebraciones privadas
        en todo Palm Beach County.
      </p>
      <a href="#quote" class="btn-spice mt-9">Solicita tu cotización</a>
    </div>
  </section>

  <!-- CONFÍAN EN NOSOTROS -->
  <section class="border-b border-navy-100 bg-white py-12">
    <div class="container-x text-center">
      <p class="eyebrow">Con la confianza de los mejores clubes de Palm Beach County</p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-x-12 gap-y-6">
        {site.trustedBy.map((venue) => (
          <SmartImage
            src={venue.logo}
            alt={venue.name}
            class="h-12 w-auto object-contain opacity-70 grayscale transition-all hover:opacity-100 hover:grayscale-0 lg:h-14"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- CÓMO FUNCIONA -->
  <section class="container-x py-20 lg:py-24">
    <div class="mx-auto max-w-2xl text-center">
      <p class="eyebrow">Simple y sin estrés</p>
      <h2 class="mt-3 text-balance font-display text-4xl font-bold text-navy md:text-5xl">Cómo funciona</h2>
    </div>

    <div class="mt-14 grid gap-8 md:grid-cols-3">
      <div class="rounded-3xl bg-white p-8 shadow-card">
        <div class="flex h-12 w-12 items-center justify-center rounded-full bg-marigold/20 font-display text-xl font-bold text-marigold-dark">1</div>
        <h3 class="mt-5 font-display text-xl font-bold text-navy">Cuéntanos tu visión</h3>
        <p class="mt-3 font-body text-ink/70">
          Comparte tu fecha, número de invitados y el ambiente que buscas. ¿Banquete guatemalteco
          tradicional? ¿Barra de tacos? ¿Estación de La Parrillada? Lo armamos juntos.
        </p>
      </div>
      <div class="rounded-3xl bg-white p-8 shadow-card">
        <div class="flex h-12 w-12 items-center justify-center rounded-full bg-marigold/20 font-display text-xl font-bold text-marigold-dark">2</div>
        <h3 class="mt-5 font-display text-xl font-bold text-navy">Recibe tu menú a la medida</h3>
        <p class="mt-3 font-body text-ink/70">
          En menos de 24 horas, Silvia te envía una propuesta de menú y precios claros hechos
          para tu evento — con opciones para toda necesidad dietética.
        </p>
      </div>
      <div class="rounded-3xl bg-white p-8 shadow-card">
        <div class="flex h-12 w-12 items-center justify-center rounded-full bg-marigold/20 font-display text-xl font-bold text-marigold-dark">3</div>
        <h3 class="mt-5 font-display text-xl font-bold text-navy">Nosotros nos encargamos</h3>
        <p class="mt-3 font-body text-ink/70">
          Preparación fresca, entrega puntual o servicio completo, presentación hermosa.
          Tú disfrutas la fiesta; nosotros nos encargamos de la comida.
        </p>
      </div>
    </div>
  </section>

  <!-- FORMULARIO -->
  <section id="quote" class="scroll-mt-24 bg-cream-200/50 py-20 lg:py-24">
    <div class="container-x">
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow">Planeemos tu evento</p>
        <h2 class="mt-3 text-balance font-display text-4xl font-bold text-navy md:text-5xl">
          Solicita tu cotización
        </h2>
        <p class="mt-4 font-body text-lg text-ink/75">
          Cuéntanos de tu celebración y te respondemos en menos de 24 horas — todos los días de la semana.
        </p>
      </div>
      <div class="mt-12">
        <CateringForm lang="es" />
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="container-x py-16 text-center">
    <p class="font-body text-lg text-ink/75">
      ¿Prefieres platicarlo?
      <a href={`tel:${site.phoneTel}`} class="font-semibold text-spice hover:underline">Llama al {site.phone}</a>
      — a Silvia le encanta planear menús.
    </p>
  </section>
</BaseLayout>
