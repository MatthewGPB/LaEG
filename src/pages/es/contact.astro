---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactForm from '../../components/ContactForm.astro';
import site from '../../data/site.json';

const description = "Contacta a La Esquina Guatemalteca en Jupiter, FL. Preguntas, comentarios, prensa o solo para saludar — envíanos un mensaje o llama al 561-768-9137.";

const alternates = [
  { hreflang: 'en', href: site.domain + '/contact' },
  { hreflang: 'es', href: site.domain + '/es/contact' },
  { hreflang: 'x-default', href: site.domain + '/contact' },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: `Contacto ${site.name}`,
  url: site.domain + '/es/contact',
  inLanguage: 'es',
};
---

<BaseLayout
  title="Contáctanos"
  description={description}
  path="/es/contact"
  schema={schema}
  lang="es"
  alternates={alternates}
>
  <section class="container-x pt-14 pb-10 text-center lg:pt-20">
    <p class="eyebrow">Salúdanos</p>
    <h1 class="mt-3 text-balance font-display text-5xl font-bold text-navy md:text-6xl">
      Nos encantaría saber de ti
    </h1>
    <p class="mx-auto mt-5 max-w-2xl font-body text-lg text-ink/75">
      Preguntas, comentarios, prensa, objetos perdidos o solo para saludar — déjanos una nota abajo.
      Para catering y reservas del food truck, usa los formularios de esas páginas para ayudarte más rápido.
    </p>
  </section>

  <section class="container-x pb-14">
    <div class="mx-auto grid max-w-4xl gap-4 sm:grid-cols-3">
      <a href={`tel:${site.phoneTel}`} class="rounded-2xl bg-white p-6 text-center shadow-soft transition-transform hover:-translate-y-0.5">
        <p class="font-display text-lg font-bold text-navy">Llama</p>
        <p class="mt-1 font-body text-sm text-spice">{site.phone}</p>
      </a>
      <a href="/es/catering" class="rounded-2xl bg-white p-6 text-center shadow-soft transition-transform hover:-translate-y-0.5">
        <p class="font-display text-lg font-bold text-navy">Catering</p>
        <p class="mt-1 font-body text-sm text-spice">Pedir cotización →</p>
      </a>
      <a href="/es/food-truck" class="rounded-2xl bg-white p-6 text-center shadow-soft transition-transform hover:-translate-y-0.5">
        <p class="font-display text-lg font-bold text-navy">Food Truck</p>
        <p class="mt-1 font-body text-sm text-spice">Reservar Guatamigos →</p>
      </a>
    </div>
  </section>

  <section class="container-x pb-24">
    <div class="mx-auto max-w-2xl rounded-3xl bg-white p-8 shadow-card md:p-12">
      <ContactForm lang="es" />
    </div>
  </section>
</BaseLayout>
