---
import BaseLayout from '../layouts/BaseLayout.astro';
import SignatureCarousel from '../components/SignatureCarousel.astro';
import SmartImage from '../components/SmartImage.astro';
import site from '../data/site.json';
import menu from '../data/menu.json';

const description = "Family-run Guatemalan restaurant in Jupiter, FL serving authentic homemade tacos, La Parrillada, Pepián, empanadas, and weekly $10 specials. Dine in, takeout, catering and the Guatamigos food truck.";

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Restaurant',
  '@id': site.domain + '/#restaurant',
  name: site.name,
  description: description,
  url: site.domain,
  telephone: site.phoneTel,
  servesCuisine: ['Guatemalan', 'Latin American', 'Central American'],
  priceRange: '$$',
  acceptsReservations: 'True',
  hasMenu: site.domain + '/menu',
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.address.street,
    addressLocality: site.address.city,
    addressRegion: site.address.region,
    postalCode: site.address.postalCode,
    addressCountry: site.address.country,
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: site.address.lat,
    longitude: site.address.lng,
  },
  openingHoursSpecification: [{
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'],
    opens: site.hours.schemaOpens,
    closes: site.hours.schemaCloses,
  }],
  image: site.domain + '/LAEG/hero-mural.jpeg',
  sameAs: [site.social.instagram, site.social.facebook],
  founder: { '@type': 'Person', name: site.founder },
  foundingDate: site.founded,
};
---

<BaseLayout
  title={`${site.name} — Authentic Guatemalan Food in Jupiter, FL`}
  description={description}
  path="/"
  image="/LAEG/hero-mural.jpeg"
  schema={schema}
  showPopup={true}
>
  <!-- HERO -->
  <section class="relative isolate overflow-hidden">
    <div class="absolute inset-0 -z-10">
      <SmartImage
        src="/LAEG/hero-mural.jpeg"
        alt="Authentic Guatemalan restaurant in Jupiter, Florida"
        class="h-full w-full object-cover"
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-gradient-to-br from-navy/85 via-navy/65 to-navy/85"></div>
    </div>

    <div class="container-x relative py-24 lg:py-36">
      <div class="max-w-3xl">
        <p class="eyebrow text-marigold">Jupiter, FL · Family-run since 2018</p>
        <h1 class="mt-4 text-balance font-display text-5xl font-bold leading-[1.05] text-cream md:text-7xl">
          Authentic Guatemalan Food
          <span class="italic text-marigold">in Jupiter, FL</span>
        </h1>
        <p class="mt-7 max-w-2xl text-pretty font-body text-lg leading-relaxed text-cream/85 md:text-xl">
          <span class="italic text-cream/95">La cocina de la familia</span> — homemade Guatemalan flavors
          made fresh every day. Tacos, La Parrillada, Pepián, and the warm welcome of a real family
          kitchen. Right here on Hibiscus St.
        </p>
        <div class="mt-10 flex flex-wrap gap-4">
          <a href={site.orderUrl} target="_blank" rel="noopener" class="btn-spice text-base">
            Order online
          </a>
          <a href={site.directionsUrl} target="_blank" rel="noopener" class="rounded-full border-2 border-cream/40 bg-cream/10 px-7 py-3 font-body font-semibold text-cream backdrop-blur-sm transition-colors hover:bg-cream hover:text-navy">
            Visit us in Jupiter
          </a>
        </div>

        <div class="mt-12 flex flex-wrap items-center gap-x-8 gap-y-3 text-sm text-cream/75">
          <span class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-marigold"></span> Open Mon–Sun 11am–9pm</span>
          <span class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-marigold"></span> Dine-in · Takeout · Catering</span>
          <span class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-marigold"></span> {site.phone}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- THREE OFFERINGS -->
  <section class="container-x -mt-12 grid gap-5 md:grid-cols-3 lg:-mt-16">
    <a href="/menu" class="group relative overflow-hidden rounded-3xl bg-white p-7 shadow-card transition-transform hover:-translate-y-1">
      <div class="absolute right-0 top-0 h-24 w-24 rounded-bl-full bg-marigold/20 transition-colors group-hover:bg-marigold/40"></div>
      <p class="eyebrow relative">The Menu</p>
      <h3 class="relative mt-2 font-display text-2xl font-bold text-navy">Dine in &amp; takeout</h3>
      <p class="relative mt-3 font-body text-ink/70">Full menu, weekly $10 specials, and homemade tortillas every day.</p>
      <span class="relative mt-5 inline-flex items-center gap-2 font-semibold text-spice">Explore menu →</span>
    </a>

    <a href="/catering" class="group relative overflow-hidden rounded-3xl bg-white p-7 shadow-card transition-transform hover:-translate-y-1">
      <div class="absolute right-0 top-0 h-24 w-24 rounded-bl-full bg-spice/15 transition-colors group-hover:bg-spice/30"></div>
      <p class="eyebrow relative">Catering</p>
      <h3 class="relative mt-2 font-display text-2xl font-bold text-navy">For your celebration</h3>
      <p class="relative mt-3 font-body text-ink/70">Country clubs, weddings, corporate. Custom menus, professionally served.</p>
      <span class="relative mt-5 inline-flex items-center gap-2 font-semibold text-spice">Request a quote →</span>
    </a>

    <a href="/food-truck" class="group relative overflow-hidden rounded-3xl bg-white p-7 shadow-card transition-transform hover:-translate-y-1">
      <div class="absolute right-0 top-0 h-24 w-24 rounded-bl-full bg-navy/10 transition-colors group-hover:bg-navy/25"></div>
      <p class="eyebrow relative">Guatamigos</p>
      <h3 class="relative mt-2 font-display text-2xl font-bold text-navy">The food truck</h3>
      <p class="relative mt-3 font-body text-ink/70">Our mobile kitchen rolls into private events around Palm Beach County.</p>
      <span class="relative mt-5 inline-flex items-center gap-2 font-semibold text-spice">Book the truck →</span>
    </a>
  </section>

  <!-- SIGNATURE CAROUSEL -->
  <SignatureCarousel />

  <!-- STORY TEASER -->
  <section class="bg-navy/95 py-20 text-cream lg:py-28">
    <div class="container-x grid items-center gap-12 lg:grid-cols-2">
      <div class="overflow-hidden rounded-3xl shadow-deep">
        <SmartImage
          src="/LAEG/family.jpeg"
          alt="The Cano family at La Esquina Guatemalteca"
          class="aspect-[4/5] w-full object-cover"
        />
      </div>
      <div>
        <p class="eyebrow text-marigold">Our Story</p>
        <h2 class="mt-3 text-balance font-display text-4xl font-bold md:text-5xl">
          A dream rooted in Huehuetenango.
        </h2>
        <p class="mt-6 text-pretty font-body text-lg leading-relaxed text-cream/85">
          Silvia Cano learned to cook in her mother-in-law's family kitchen — no written recipes,
          just the perfect touch. When she and Santos moved to Jupiter with their boys, Guatemala
          came along through the food. Today the whole family runs this corner.
        </p>
        <blockquote class="mt-7 border-l-4 border-marigold pl-5 font-display text-xl italic text-cream/95">
          "Muy feliz" — very happy — that's how I feel every day in this kitchen.
          <footer class="mt-2 font-body text-sm not-italic text-cream/70">— Silvia Cano, Owner &amp; Chef</footer>
        </blockquote>
        <a href="/about" class="btn-secondary mt-8 border-cream text-cream hover:bg-cream hover:text-navy">
          Read our full story
        </a>
      </div>
    </div>
  </section>

  <!-- WEEKLY SPECIALS PREVIEW -->
  <section class="container-x py-20 lg:py-24">
    <div class="mx-auto max-w-2xl text-center">
      <p class="eyebrow">$10 Weekly Specials</p>
      <h2 class="mt-3 text-balance font-display text-4xl font-bold text-navy md:text-5xl">
        A different favorite, every weekday.
      </h2>
      <p class="mt-5 text-pretty font-body text-lg leading-relaxed text-ink/75">
        Quick, delicious, budget-friendly — perfect for college students, families on the go,
        or anyone craving authentic Guatemalan flavors.
      </p>
    </div>

    <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {menu.weeklySpecials.map((special) => (
        <article class="overflow-hidden rounded-3xl bg-white shadow-card transition-transform hover:-translate-y-1">
          <SmartImage src={special.image} alt={special.name} class="h-52 w-full object-cover" />
          <div class="p-6">
            <h3 class="font-display text-xl font-bold text-navy">{special.name}</h3>
            <p class="mt-2 font-body text-sm leading-relaxed text-ink/70">{special.description}</p>
            <p class="mt-4 font-display text-2xl font-bold text-price">{special.price}</p>
          </div>
        </article>
      ))}
    </div>

    <div class="mt-12 text-center">
      <a href="/menu" class="btn-primary">See the full menu</a>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="bg-gradient-to-br from-navy via-navy-600 to-navy py-20 text-cream lg:py-24">
    <div class="container-x mx-auto max-w-3xl text-center">
      <h2 class="text-balance font-display text-4xl font-bold md:text-5xl">
        Hungry? <span class="text-marigold">We're right around the corner.</span>
      </h2>
      <p class="mt-5 font-body text-lg text-cream/85">
        Fresh, hot, authentic Guatemalan food — dine in, takeout, or delivered to your door.
      </p>
      <div class="mt-9 flex flex-wrap justify-center gap-4">
        <a href={site.orderUrl} target="_blank" rel="noopener" class="btn-spice">Order takeout now</a>
        <a href={`tel:${site.phoneTel}`} class="btn-secondary border-cream text-cream hover:bg-cream hover:text-navy">
          Call {site.phone}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
