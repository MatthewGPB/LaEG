---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import site from '../data/site.json';

const description = `Get in touch with La Esquina Guatemalteca in Jupiter, FL. Call ${site.phone}, message us, or stop by 200 Hibiscus St.`;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: `Contact ${site.name}`,
  url: site.domain + '/contact',
  about: {
    '@type': 'Restaurant',
    name: site.name,
    telephone: site.phoneTel,
    address: {
      '@type': 'PostalAddress',
      streetAddress: site.address.street,
      addressLocality: site.address.city,
      addressRegion: site.address.region,
      postalCode: site.address.postalCode,
    },
  },
};
---

<BaseLayout
  title="Contact Us"
  description={description}
  path="/contact"
  schema={schema}
>
  <section class="container-x py-16 text-center lg:py-20">
    <p class="eyebrow">Say hola</p>
    <h1 class="mx-auto mt-3 max-w-2xl text-balance font-display text-5xl font-bold text-navy md:text-6xl">
      We'd love to hear from you.
    </h1>
    <p class="mx-auto mt-5 max-w-2xl font-body text-lg text-ink/75">
      Questions about the menu, allergies, a private gathering, or just want to say hi? Message us
      and Silvia will reply within 24 hours.
    </p>
  </section>

  <!-- Contact info strip -->
  <section class="container-x">
    <div class="grid gap-6 md:grid-cols-3">
      <a href={`tel:${site.phoneTel}`} class="group rounded-3xl border border-navy-100 bg-white p-7 text-center shadow-soft transition-transform hover:-translate-y-1 hover:shadow-card">
        <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-navy text-cream transition-colors group-hover:bg-spice">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        </div>
        <p class="mt-4 eyebrow">Phone</p>
        <p class="mt-1 font-display text-xl font-bold text-navy">{site.phone}</p>
        <p class="mt-1 font-body text-sm text-ink/60">Mon–Sun · 11am–9pm</p>
      </a>

      <a href={site.directionsUrl} target="_blank" rel="noopener" class="group rounded-3xl border border-navy-100 bg-white p-7 text-center shadow-soft transition-transform hover:-translate-y-1 hover:shadow-card">
        <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-navy text-cream transition-colors group-hover:bg-spice">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        </div>
        <p class="mt-4 eyebrow">Visit</p>
        <p class="mt-1 font-display text-xl font-bold text-navy">{site.address.street}</p>
        <p class="mt-1 font-body text-sm text-ink/60">{site.address.city}, {site.address.region} {site.address.postalCode}</p>
      </a>

      <a href={site.social.instagram} target="_blank" rel="noopener" class="group rounded-3xl border border-navy-100 bg-white p-7 text-center shadow-soft transition-transform hover:-translate-y-1 hover:shadow-card">
        <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-navy text-cream transition-colors group-hover:bg-spice">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069z"/></svg>
        </div>
        <p class="mt-4 eyebrow">Social</p>
        <p class="mt-1 font-display text-xl font-bold text-navy">{site.social.instagramHandle}</p>
        <p class="mt-1 font-body text-sm text-ink/60">Daily updates &amp; specials</p>
      </a>
    </div>
  </section>

  <!-- FORM -->
  <section class="container-x py-16 lg:py-20">
    <div class="rounded-3xl bg-white p-7 shadow-card md:p-12">
      <ContactForm />
    </div>
  </section>
</BaseLayout>
