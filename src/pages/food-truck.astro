---
import BaseLayout from '../layouts/BaseLayout.astro';
import FoodTruckForm from '../components/FoodTruckForm.astro';
import SmartImage from '../components/SmartImage.astro';
import site from '../data/site.json';
import events from '../data/events.json';

const description = "Book Guatamigos — the Guatemalan food truck from La Esquina Guatemalteca. Premium mobile catering for weddings, corporate events, parties & festivals in Jupiter, Palm Beach County & beyond.";

const schema = {
  '@context': 'https://schema.org',
  '@type': 'FoodEstablishment',
  '@id': site.domain + '/food-truck#truck',
  name: 'Guatamigos Food Truck — La Esquina Guatemalteca',
  description: description,
  url: site.domain + '/food-truck',
  telephone: site.phoneTel,
  servesCuisine: ['Guatemalan', 'Latin American'],
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.address.street,
    addressLocality: site.address.city,
    addressRegion: site.address.region,
    postalCode: site.address.postalCode,
    addressCountry: site.address.country,
  },
  image: site.domain + '/LAEG/food-truck-hero.jpeg',
  sameAs: [site.social.guatamigosInstagram],
  areaServed: site.areaServed.map((a) => ({ '@type': 'City', name: a })),
};
---

<BaseLayout
  title="Guatamigos Food Truck — Book for Your Event"
  description={description}
  path="/food-truck"
  image="/LAEG/food-truck-hero.jpeg"
  schema={schema}
>
  <!-- HERO -->
  <section class="relative isolate overflow-hidden">
    <div class="absolute inset-0 -z-10">
      <SmartImage
        src="/LAEG/food-truck-hero.jpeg"
        alt="Guatamigos Guatemalan food truck event catering"
        class="h-full w-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-br from-navy/85 via-navy/55 to-spice/55"></div>
    </div>
    <div class="container-x relative py-28 text-cream lg:py-36">
      <div class="max-w-3xl">
        <p class="eyebrow text-marigold">Guatamigos · The Food Truck</p>
        <h1 class="mt-4 text-balance font-display text-5xl font-bold leading-[1.05] md:text-7xl">
          Our mobile kitchen, <span class="italic text-marigold">your event.</span>
        </h1>
        <p class="mt-7 max-w-2xl text-pretty font-body text-lg leading-relaxed text-cream/85 md:text-xl">
          Premium Guatemalan tacos, empanadas, and homemade flavors brought to your event —
          weddings, birthdays, corporate gatherings, festivals.
        </p>
        <div class="mt-10 flex flex-wrap gap-4">
          <a href="#book-truck" class="btn-spice">Book the truck</a>
          <a
            href={site.social.guatamigosInstagram}
            target="_blank"
            rel="noopener"
            class="rounded-full border-2 border-cream/40 bg-cream/10 px-7 py-3 font-body font-semibold text-cream backdrop-blur-sm transition-colors hover:bg-cream hover:text-navy"
          >
            Follow {site.social.guatamigosHandle}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- SELL -->
  <section class="container-x py-20 text-center lg:py-24">
    <div class="mx-auto max-w-3xl">
      <h2 class="text-balance font-display text-4xl font-bold text-navy md:text-5xl">
        Your event, our family recipes.
      </h2>
      <p class="mt-6 text-pretty font-body text-lg leading-relaxed text-ink/80">
        Guatamigos is our mobile kitchen — bringing the same authentic, homemade Guatemalan flavors
        you love from La Esquina straight to your event. Custom menus, fresh ingredients, vibrant service.
        Perfect for weddings, birthdays, corporate lunches, tailgates, holiday parties, and more.
      </p>
      <p class="mt-4 font-display text-xl font-semibold text-spice">
        Event-booked only — we come to you.
      </p>
    </div>
  </section>

  <!-- TRUST LOGOS (same venues) -->
  <section class="border-y border-navy-100 bg-white py-14 lg:py-16">
    <div class="container-x text-center">
      <p class="eyebrow">Trusted by premier venues</p>
      <h2 class="mt-2 font-display text-2xl font-semibold text-navy md:text-3xl">
        Where we've rolled in
      </h2>
      <div class="mt-10 grid grid-cols-2 items-center gap-x-8 gap-y-10 sm:grid-cols-3 lg:grid-cols-5">
        {site.trustedBy.map((venue) => (
          <div class="flex h-16 items-center justify-center">
            <SmartImage
              src={venue.logo}
              alt={venue.name}
              class="max-h-12 w-auto object-contain opacity-70 grayscale transition-all hover:opacity-100 hover:grayscale-0"
              loading="lazy"
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- BOOKING FORM -->
  <section id="book-truck" class="bg-cream-200/40 py-20 lg:py-24">
    <div class="container-x">
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow">24-hour reply</p>
        <h2 class="mt-3 text-balance font-display text-4xl font-bold text-navy md:text-5xl">
          Book Guatamigos for your event
        </h2>
        <p class="mt-5 font-body text-lg text-ink/75">
          Tell us about your event — we'll reply within 24 hours with a custom quote.
        </p>
      </div>
      <div class="mt-12 rounded-3xl bg-white p-7 shadow-card md:p-10">
        <FoodTruckForm />
      </div>
    </div>
  </section>

  <!-- 2026 EVENTS -->
  {events.events.length > 0 && (
    <section class="container-x py-20 lg:py-24">
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow">{new Date().getFullYear()} Featured Events</p>
        <h2 class="mt-3 text-balance font-display text-4xl font-bold text-navy md:text-5xl">
          Where to find us next
        </h2>
        <p class="mt-5 font-body text-lg text-ink/75">
          We book private events year-round. Here's where you can find Guatamigos in public.
          Follow <a href={site.social.guatamigosInstagram} target="_blank" rel="noopener" class="font-semibold text-spice underline">{site.social.guatamigosHandle}</a> for real-time updates.
        </p>
      </div>

      <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {events.events.map((event) => (
          <article class="rounded-3xl border-l-4 border-marigold bg-white p-7 shadow-soft transition-shadow hover:shadow-card">
            <p class="eyebrow">{event.date}</p>
            <h3 class="mt-2 font-display text-xl font-bold text-navy">{event.title}</h3>
            <p class="mt-3 font-body text-sm text-ink/70">{event.type} · {event.menu}</p>
          </article>
        ))}
      </div>
    </section>
  )}
</BaseLayout>
