---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../data/site.json';
---

<BaseLayout
  title="Page Not Found"
  description="This page wandered off — but the kitchen is still open."
  path="/404"
  noindex={true}
>
  <section class="container-x flex min-h-[60vh] flex-col items-center justify-center py-20 text-center">
    <p class="eyebrow">404</p>
    <h1 class="mt-3 text-balance font-display text-5xl font-bold text-navy">
      This page wandered off…
    </h1>
    <p class="mx-auto mt-4 max-w-xl font-body text-lg text-ink/75">
      …but the tortillas are still warm. Let's get you back to the good stuff.
    </p>
    <div class="mt-9 flex flex-wrap justify-center gap-4">
      <a href="/" class="btn-primary">Back to home</a>
      <a href="/menu" class="btn-secondary">See the menu</a>
      <a href={site.orderUrl} target="_blank" rel="noopener" class="btn-spice">Order takeout</a>
    </div>
  </section>
</BaseLayout>
