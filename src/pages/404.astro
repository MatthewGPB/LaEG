---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../data/site.json';
---

<BaseLayout
  title="Page Not Found"
  description="The page you were looking for doesn't exist — but we have plenty of Guatemalan flavors waiting for you."
  path="/404"
  noindex={true}
>
  <section class="container-x py-24 text-center lg:py-32">
    <div class="mx-auto max-w-2xl">
      <p class="eyebrow">404 · Not found</p>
      <h1 class="mt-4 text-balance font-display text-6xl font-bold text-navy md:text-8xl">
        ¡Ay, no!
      </h1>
      <p class="mt-6 text-pretty font-body text-lg leading-relaxed text-ink/80 md:text-xl">
        We couldn't find that page — but we did just pull a fresh batch of tortillas off the comal.
        Let's get you back to something delicious.
      </p>

      <div class="mt-10 flex flex-wrap justify-center gap-4">
        <a href="/" class="btn-primary">Home</a>
        <a href="/menu" class="btn-secondary">Menu</a>
        <a href={site.orderUrl} target="_blank" rel="noopener" class="btn-spice">Order takeout</a>
      </div>

      <p class="mt-12 font-body text-base text-ink/65">
        Or call us at
        <a href={`tel:${site.phoneTel}`} class="font-semibold text-navy hover:text-spice">{site.phone}</a>.
      </p>
    </div>
  </section>
</BaseLayout>
