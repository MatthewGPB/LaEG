---
interface Props {
  src: string;
  alt: string;
  class?: string;
  width?: number;
  height?: number;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
}

const {
  src,
  alt,
  class: className = '',
  width,
  height,
  loading = 'lazy',
  fetchpriority = 'auto',
} = Astro.props;

// SVG fallback inline data URI — matches brand colors
const fallback =
  "data:image/svg+xml;utf8," +
  encodeURIComponent(
    `<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 400 300'>
      <defs>
        <linearGradient id='g' x1='0' y1='0' x2='1' y2='1'>
          <stop offset='0' stop-color='#1e3a5f'/>
          <stop offset='1' stop-color='#3a6ea5'/>
        </linearGradient>
      </defs>
      <rect width='400' height='300' fill='url(#g)'/>
      <text x='50%' y='50%' fill='#fdf8f0' font-family='Georgia,serif' font-size='28' text-anchor='middle' opacity='0.95'>La Esquina</text>
      <text x='50%' y='62%' fill='#fdf8f0' font-family='Georgia,serif' font-size='16' text-anchor='middle' opacity='0.75'>Guatemalteca</text>
    </svg>`
  );
---

<img
  src={src}
  alt={alt}
  class={className}
  width={width}
  height={height}
  loading={loading}
  fetchpriority={fetchpriority}
  decoding="async"
  onerror={`this.onerror=null;this.src='${fallback}';`}
/>
