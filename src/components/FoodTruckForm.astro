---
import site from '../data/site.json';

interface Props {
  lang?: 'en' | 'es';
}

const { lang = 'en' } = Astro.props;

const T = lang === 'es'
  ? {
      name: 'Tu nombre *', email: 'Correo electrónico *', phone: 'Teléfono *',
      guests: 'Invitados estimados', guestsPh: 'ej., 50',
      date: 'Fecha y hora del evento', datePh: 'ej., 15 de junio de 2026 a las 6:00 PM',
      location: 'Lugar del evento', locationPh: 'Dirección o lugar',
      message: 'Cuéntanos sobre tu evento *', messagePh: 'Recepción de boda, almuerzo corporativo, fiesta de vecinos… ¿qué celebramos?',
      send: 'Enviar solicitud de reserva', sending: 'Enviando…', reply: 'Respondemos en 24 horas',
      successTitle: '¡Gracias!', success: 'Recibimos tu solicitud de reserva. Nuestro equipo te contactará dentro de 24 horas.',
      error: 'Algo salió mal. Por favor llama al',
    }
  : {
      name: 'Your name *', email: 'Email *', phone: 'Phone *',
      guests: 'Expected guests', guestsPh: 'e.g., 50',
      date: 'Event date & time', datePh: 'e.g., June 15, 2026 at 6:00 PM',
      location: 'Event location', locationPh: 'Address or venue',
      message: 'Tell us about your event *', messagePh: 'Wedding reception, corporate lunch, block party… what are we celebrating?',
      send: 'Send booking request', sending: 'Sending…', reply: 'We reply within 24 hours',
      successTitle: '¡Gracias!', success: 'We received your booking request. Our team will reach out within 24 hours.',
      error: 'Something went wrong. Please call',
    };
---

<form
  class="form-wrap mx-auto max-w-2xl space-y-5"
  action={site.formspree.foodTruck}
  method="POST"
  data-form-name="food-truck"
  data-sending-label={T.sending}
>
  <input type="hidden" name="_subject" value="New GUATAMIGOS food truck booking — laesquinaguatemalteca.com" />
  <input type="hidden" name="form_type" value="food-truck" />
  <input type="hidden" name="language" value={lang} />

  <div class="grid gap-5 md:grid-cols-2">
    <div>
      <label for="ft-name" class="label-field">{T.name}</label>
      <input id="ft-name" name="name" type="text" required class="input-field" autocomplete="name" />
    </div>
    <div>
      <label for="ft-email" class="label-field">{T.email}</label>
      <input id="ft-email" name="email" type="email" required class="input-field" autocomplete="email" />
    </div>
  </div>

  <div class="grid gap-5 md:grid-cols-2">
    <div>
      <label for="ft-phone" class="label-field">{T.phone}</label>
      <input id="ft-phone" name="phone" type="tel" required class="input-field" autocomplete="tel" />
    </div>
    <div>
      <label for="ft-guests" class="label-field">{T.guests}</label>
      <input id="ft-guests" name="guests" type="number" min="20" placeholder={T.guestsPh} class="input-field" />
    </div>
  </div>

  <div>
    <label for="ft-date" class="label-field">{T.date}</label>
    <input id="ft-date" name="event_date" type="text" placeholder={T.datePh} class="input-field" />
  </div>

  <div>
    <label for="ft-location" class="label-field">{T.location}</label>
    <input id="ft-location" name="location" type="text" placeholder={T.locationPh} class="input-field" />
  </div>

  <div>
    <label for="ft-message" class="label-field">{T.message}</label>
    <textarea id="ft-message" name="message" rows="5" required class="input-field resize-y" placeholder={T.messagePh}></textarea>
  </div>

  <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" class="absolute left-[-9999px]" aria-hidden="true" />

  <div class="text-center">
    <button type="submit" class="btn-primary text-base">
      <span class="btn-label">{T.send}</span>
    </button>
    <p class="mt-3 text-sm text-navy/60">{T.reply}</p>
  </div>

  <div class="form-success hidden rounded-2xl bg-marigold/15 p-6 text-center" role="status" aria-live="polite">
    <p class="font-display text-2xl font-bold text-navy">{T.successTitle}</p>
    <p class="mt-2 font-body text-navy-700/80">{T.success}</p>
  </div>
  <div class="form-error hidden rounded-2xl bg-spice/15 p-4 text-center text-spice-dark" role="alert">
    {T.error} <a href={`tel:${site.phoneTel}`} class="font-semibold underline">{site.phone}</a>.
  </div>
</form>
