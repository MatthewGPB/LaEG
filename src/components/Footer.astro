---
import site from '../data/site.json';

interface Props {
  lang?: 'en' | 'es';
}

const { lang = 'en' } = Astro.props;
const year = new Date().getFullYear();

const T = {
  en: {
    blurb: `Family-run since ${site.founded.split('-')[0]}. We bring the homemade flavors of Huehuetenango, Guatemala to Jupiter, Florida — one plate, one tortilla, one warm welcome at a time.`,
    visit: 'Visit',
    explore: 'Explore',
    menu: 'Full Menu',
    story: 'Our Story',
    catering: 'Catering',
    foodTruck: 'Food Truck',
    hoursMap: 'Hours & Map',
    order: 'Order Online →',
    rights: `Made with love in Jupiter, FL. Proudly serving Jupiter, Tequesta, Palm Beach Gardens, Juno Beach & all of Palm Beach County.`,
    prefix: '',
    hours: site.hours.regular,
  },
  es: {
    blurb: `Negocio familiar desde ${site.founded.split('-')[0]}. Traemos los sabores caseros de Huehuetenango, Guatemala a Jupiter, Florida — un plato, una tortilla y una cálida bienvenida a la vez.`,
    visit: 'Visítanos',
    explore: 'Explora',
    menu: 'Menú Completo',
    story: 'Nuestra Historia',
    catering: 'Catering',
    foodTruck: 'Food Truck',
    hoursMap: 'Horario y Mapa',
    order: 'Ordenar en Línea →',
    rights: `Hecho con amor en Jupiter, FL. Orgullosamente servimos a Jupiter, Tequesta, Palm Beach Gardens, Juno Beach y todo Palm Beach County.`,
    prefix: '/es',
    hours: '11:00 AM – 9:00 PM, lunes a domingo',
  },
};

const t = T[lang];
const p = t.prefix;
---

<footer class="mt-24 bg-navy text-cream">
  <div class="textile-divider opacity-100" aria-hidden="true"></div>

  <div class="container-x py-16 lg:py-20">
    <div class="grid gap-12 lg:grid-cols-4">
      <!-- Brand block -->
      <div class="lg:col-span-2">
        <a href={lang === 'es' ? '/es/' : '/'} class="flex items-center gap-3" aria-label="La Esquina Guatemalteca">
          <div class="flex h-12 w-12 items-center justify-center rounded-full bg-cream text-navy">
            <span class="font-display text-xl font-bold">LE</span>
          </div>
          <div class="flex flex-col leading-none">
            <span class="font-display text-xl font-semibold">La Esquina</span>
            <span class="font-body text-xs uppercase tracking-[0.25em] text-marigold">Guatemalteca</span>
          </div>
        </a>
        <p class="mt-6 max-w-md font-body text-sm leading-relaxed text-cream/80">
          {t.blurb}
        </p>
        <div class="mt-6 flex gap-3">
          <a
            href={site.social.instagram}
            target="_blank"
            rel="noopener"
            aria-label="Instagram"
            class="flex h-10 w-10 items-center justify-center rounded-full border border-cream/30 text-cream transition-colors hover:bg-cream hover:text-navy"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069z"/></svg>
          </a>
          <a
            href={site.social.facebook}
            target="_blank"
            rel="noopener"
            aria-label="Facebook"
            class="flex h-10 w-10 items-center justify-center rounded-full border border-cream/30 text-cream transition-colors hover:bg-cream hover:text-navy"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/></svg>
          </a>
          <a
            href={site.social.guatamigosInstagram}
            target="_blank"
            rel="noopener"
            aria-label="Guatamigos Food Truck Instagram"
            class="flex h-10 items-center gap-2 rounded-full border border-cream/30 px-4 text-xs font-semibold uppercase tracking-wider transition-colors hover:bg-cream hover:text-navy"
          >
            Guatamigos
          </a>
        </div>
      </div>

      <!-- Visit -->
      <div>
        <h3 class="font-display text-lg font-semibold text-marigold">{t.visit}</h3>
        <address class="mt-4 not-italic font-body text-sm leading-relaxed text-cream/80">
          {site.address.street}<br />
          {site.address.city}, {site.address.region} {site.address.postalCode}<br />
          <a href={`tel:${site.phoneTel}`} class="mt-2 inline-block font-semibold text-cream hover:text-marigold">
            {site.phone}
          </a>
        </address>
        <p class="mt-4 font-body text-sm text-cream/80">{t.hours}</p>
      </div>

      <!-- Explore -->
      <div>
        <h3 class="font-display text-lg font-semibold text-marigold">{t.explore}</h3>
        <ul class="mt-4 flex flex-col gap-2 font-body text-sm">
          <li><a href={`${p}/menu`} class="text-cream/80 hover:text-cream">{t.menu}</a></li>
          <li><a href={`${p}/about`} class="text-cream/80 hover:text-cream">{t.story}</a></li>
          <li><a href={`${p}/catering`} class="text-cream/80 hover:text-cream">{t.catering}</a></li>
          <li><a href={`${p}/food-truck`} class="text-cream/80 hover:text-cream">{t.foodTruck}</a></li>
          <li><a href={`${p}/location`} class="text-cream/80 hover:text-cream">{t.hoursMap}</a></li>
          <li>
            <a href={site.orderUrl} target="_blank" rel="noopener" class="font-semibold text-marigold hover:text-cream">
              {t.order}
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-12 border-t border-cream/15 pt-6 text-center font-body text-xs text-cream/60">
      © {year} {site.name}. {t.rights}
    </div>
  </div>
</footer>
