---
import site from '../data/site.json';

interface Props {
  lang?: 'en' | 'es';
}

const { lang = 'en' } = Astro.props;

const T = lang === 'es'
  ? {
      eyebrow: 'Entrega y para llevar',
      title: '¿Antojo? Te lo llevamos.',
      sub: 'Ordena por tu app favorita — o pide directo con nosotros para las tarifas más bajas.',
      doordash: 'Pedir en DoorDash',
      doordashSub: 'Entrega a domicilio',
      uber: 'Pedir en Uber Eats',
      uberSub: 'Entrega a domicilio',
      takeout: 'Para llevar (¡tarifas más bajas!)',
      takeoutSub: 'Ordena directo — recoge en el restaurante',
      call: 'O llama al',
    }
  : {
      eyebrow: 'Delivery & Takeout',
      title: 'Craving it? We deliver.',
      sub: 'Order through your favorite app — or order direct with us for the lowest fees.',
      doordash: 'Order on DoorDash',
      doordashSub: 'Delivered to your door',
      uber: 'Order on Uber Eats',
      uberSub: 'Delivered to your door',
      takeout: 'Order Takeout (Lowest Fees!)',
      takeoutSub: 'Order direct — pick up at the restaurant',
      call: 'Or call',
    };
---

<section class="container-x py-16 lg:py-20" id="delivery">
  <div class="mx-auto max-w-2xl text-center">
    <p class="eyebrow">{T.eyebrow}</p>
    <h2 class="mt-3 text-balance font-display text-4xl font-bold text-navy md:text-5xl">
      {T.title}
    </h2>
    <p class="mt-4 text-pretty font-body text-lg leading-relaxed text-ink/75">
      {T.sub}
    </p>
  </div>

  <div class="mt-10 grid gap-5 md:grid-cols-3">
    <!-- DoorDash -->
    <a
      href={site.delivery.doordash}
      target="_blank"
      rel="noopener"
      class="group flex items-center gap-4 rounded-3xl border border-navy-100 bg-white p-6 shadow-soft transition-all hover:-translate-y-1 hover:shadow-card"
    >
      <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-[#eb1700]/10 text-[#eb1700]">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M22.5 9.7c-1-1.9-3-3.2-5.2-3.2H1.9c-.5 0-.9.4-.9.9s.4.9.9.9h3.4c.3 0 .5.1.7.3l2.2 2.2c.2.2.2.6 0 .8l-.1.1c-.2.2-.4.2-.7.2H2.5c-.5 0-.9.4-.9.9s.4.9.9.9h14.9c2.2 0 4.3-1.2 5.3-3.2.3-.6.3-1.3-.2-1.8z"/>
        </svg>
      </div>
      <div class="min-w-0">
        <p class="font-display text-lg font-bold text-navy group-hover:text-spice">{T.doordash}</p>
        <p class="font-body text-sm text-ink/60">{T.doordashSub}</p>
      </div>
      <span class="ml-auto text-navy/40 transition-transform group-hover:translate-x-1">→</span>
    </a>

    <!-- Uber Eats -->
    <a
      href={site.delivery.uberEats}
      target="_blank"
      rel="noopener"
      class="group flex items-center gap-4 rounded-3xl border border-navy-100 bg-white p-6 shadow-soft transition-all hover:-translate-y-1 hover:shadow-card"
    >
      <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-[#06c167]/10 text-[#048848]">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M4 11a8 8 0 0 1 16 0v6a3 3 0 0 1-3 3H7a3 3 0 0 1-3-3v-6z"/>
          <path d="M9 11V8a3 3 0 0 1 6 0v3"/>
        </svg>
      </div>
      <div class="min-w-0">
        <p class="font-display text-lg font-bold text-navy group-hover:text-spice">{T.uber}</p>
        <p class="font-body text-sm text-ink/60">{T.uberSub}</p>
      </div>
      <span class="ml-auto text-navy/40 transition-transform group-hover:translate-x-1">→</span>
    </a>

    <!-- Direct takeout (SkyTab) -->
    <a
      href={site.orderUrl}
      target="_blank"
      rel="noopener"
      class="group flex items-center gap-4 rounded-3xl bg-navy p-6 shadow-deep transition-all hover:-translate-y-1"
    >
      <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-marigold/20 text-marigold">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
      </div>
      <div class="min-w-0">
        <p class="font-display text-lg font-bold text-cream group-hover:text-marigold">{T.takeout}</p>
        <p class="font-body text-sm text-cream/70">{T.takeoutSub}</p>
      </div>
      <span class="ml-auto text-cream/50 transition-transform group-hover:translate-x-1">→</span>
    </a>
  </div>

  <p class="mt-8 text-center font-body text-base text-ink/65">
    {T.call}
    <a href={`tel:${site.phoneTel}`} class="font-semibold text-navy hover:text-spice">{site.phone}</a>
  </p>
</section>
