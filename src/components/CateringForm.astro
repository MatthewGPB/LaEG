---
import site from '../data/site.json';
---

<form
  class="form-wrap mx-auto max-w-2xl space-y-5"
  action={site.formspree.catering}
  method="POST"
  data-form-name="catering"
>
  <input type="hidden" name="_subject" value="New CATERING inquiry — laesquinaguatemalteca.com" />
  <input type="hidden" name="form_type" value="catering" />

  <div class="grid gap-5 md:grid-cols-2">
    <div>
      <label for="cat-name" class="label-field">Your name *</label>
      <input id="cat-name" name="name" type="text" required class="input-field" autocomplete="name" />
    </div>
    <div>
      <label for="cat-email" class="label-field">Email *</label>
      <input id="cat-email" name="email" type="email" required class="input-field" autocomplete="email" />
    </div>
  </div>

  <div class="grid gap-5 md:grid-cols-2">
    <div>
      <label for="cat-phone" class="label-field">Phone *</label>
      <input id="cat-phone" name="phone" type="tel" required class="input-field" autocomplete="tel" />
    </div>
    <div>
      <label for="cat-event-type" class="label-field">Event type</label>
      <select id="cat-event-type" name="event_type" class="input-field">
        <option value="">Select one…</option>
        <option>Wedding</option>
        <option>Corporate / Business</option>
        <option>Birthday / Anniversary</option>
        <option>Holiday (Mother's Day, 4th of July, Christmas Eve)</option>
        <option>Private celebration</option>
        <option>Other</option>
      </select>
    </div>
  </div>

  <div class="grid gap-5 md:grid-cols-2">
    <div>
      <label for="cat-date" class="label-field">Event date &amp; time</label>
      <input id="cat-date" name="event_date" type="text" placeholder="e.g., June 15, 2026 at 6:00 PM" class="input-field" />
    </div>
    <div>
      <label for="cat-guests" class="label-field">Expected guests</label>
      <input id="cat-guests" name="guests" type="number" min="20" placeholder="e.g., 75" class="input-field" />
    </div>
  </div>

  <div>
    <label for="cat-venue" class="label-field">Venue / location</label>
    <input id="cat-venue" name="venue" type="text" placeholder="Country club, home address, etc." class="input-field" />
  </div>

  <div>
    <label for="cat-message" class="label-field">Tell us about your event *</label>
    <textarea id="cat-message" name="message" rows="5" required class="input-field resize-y" placeholder="What menu vibe are you imagining? Any dietary needs? Tradition you'd like featured?"></textarea>
  </div>

  <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" class="absolute left-[-9999px]" aria-hidden="true" />

  <div class="text-center">
    <button type="submit" class="btn-primary text-base">
      <span class="btn-label">Request your custom quote</span>
    </button>
    <p class="mt-3 text-sm text-navy/60">We reply within 24 hours · 7 days a week</p>
  </div>

  <div class="form-success hidden rounded-2xl bg-marigold/15 p-6 text-center" role="status" aria-live="polite">
    <p class="font-display text-2xl font-bold text-navy">¡Gracias!</p>
    <p class="mt-2 font-body text-navy-700/80">Silvia will reach out within 24 hours with menu ideas and pricing for your event.</p>
  </div>
  <div class="form-error hidden rounded-2xl bg-spice/15 p-4 text-center text-spice-dark" role="alert">
    Something went wrong. Please call us directly at <a href={`tel:${site.phoneTel}`} class="font-semibold underline">{site.phone}</a>.
  </div>
</form>
