---
import site from '../data/site.json';

interface Props {
  lang?: 'en' | 'es';
}

const { lang = 'en' } = Astro.props;

const T = lang === 'es'
  ? {
      fab: 'Ordenar',
      sheetTitle: '¿Cómo quieres ordenar?',
      close: 'Cerrar',
      call: 'Llamar para ordenar',
      callSub: site.phone,
      takeout: 'Ordenar para llevar',
      takeoutSub: 'Recoger — ordena directo',
      badge: 'Tarifas más bajas',
      deliveryLabel: 'A domicilio',
      doordashSub: 'Entrega a domicilio',
      uberSub: 'Entrega a domicilio',
      open: 'Opciones para ordenar',
    }
  : {
      fab: 'Order',
      sheetTitle: 'How would you like to order?',
      close: 'Close',
      call: 'Call to order',
      callSub: site.phone,
      takeout: 'Order takeout',
      takeoutSub: 'Pickup — order direct',
      badge: 'Lowest fees',
      deliveryLabel: 'Delivery',
      doordashSub: 'Delivered to your door',
      uberSub: 'Delivered to your door',
      open: 'Ordering options',
    };
---

<!-- Mobile-only floating order flow -->
<div id="fob-root" class="lg:hidden">
  <!-- Floating action button -->
  <button
    type="button"
    id="fob-btn"
    aria-haspopup="dialog"
    aria-expanded="false"
    aria-controls="fob-panel"
    aria-label={T.open}
    class="fixed right-4 bottom-[calc(1.25rem+env(safe-area-inset-bottom))] z-40 inline-flex items-center gap-2 rounded-full bg-spice px-5 py-3.5 font-body text-base font-bold text-cream shadow-deep transition-transform active:scale-95 sm:right-5"
  >
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" />
      <line x1="3" y1="6" x2="21" y2="6" />
      <path d="M16 10a4 4 0 0 1-8 0" />
    </svg>
    {T.fab}
  </button>

  <!-- Backdrop -->
  <div
    id="fob-backdrop"
    class="pointer-events-none fixed inset-0 z-[80] bg-navy/50 opacity-0 backdrop-blur-sm transition-opacity duration-300"
    aria-hidden="true"
  ></div>

  <!-- Bottom sheet -->
  <div
    id="fob-panel"
    role="dialog"
    aria-modal="true"
    aria-labelledby="fob-title"
    class="fixed inset-x-0 bottom-0 z-[81] translate-y-full rounded-t-3xl bg-cream pb-[calc(1rem+env(safe-area-inset-bottom))] shadow-2xl transition-transform duration-300 will-change-transform"
  >
    <div class="mx-auto max-w-xl px-5 pt-3">
      <!-- Grabber -->
      <div class="mx-auto mb-4 h-1.5 w-10 rounded-full bg-navy/15" aria-hidden="true"></div>

      <div class="mb-4 flex items-center justify-between">
        <h2 id="fob-title" class="font-display text-xl font-bold text-navy">{T.sheetTitle}</h2>
        <button
          type="button"
          id="fob-close"
          aria-label={T.close}
          class="flex h-9 w-9 items-center justify-center rounded-full bg-white text-xl leading-none text-navy shadow-soft"
        >×</button>
      </div>

      <div class="space-y-3 pb-2">
        <!-- Call -->
        <a
          href={`tel:${site.phoneTel}`}
          class="fob-action flex items-center gap-4 rounded-2xl border border-navy-100 bg-white p-4 shadow-soft active:scale-[0.99]"
        >
          <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-navy/10 text-navy">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z" />
            </svg>
          </span>
          <span class="min-w-0 flex-1">
            <span class="block font-display text-base font-bold text-navy">{T.call}</span>
            <span class="block font-body text-sm text-ink/60">{T.callSub}</span>
          </span>
          <span class="text-navy/30">→</span>
        </a>

        <!-- Takeout (direct / best value) -->
        <a
          href={site.orderUrl}
          target="_blank"
          rel="noopener"
          class="fob-action flex items-center gap-4 rounded-2xl border-2 border-marigold bg-white p-4 shadow-soft active:scale-[0.99]"
        >
          <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-marigold/20 text-marigold-dark">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" />
              <line x1="3" y1="6" x2="21" y2="6" />
              <path d="M16 10a4 4 0 0 1-8 0" />
            </svg>
          </span>
          <span class="min-w-0 flex-1">
            <span class="flex items-center gap-2">
              <span class="font-display text-base font-bold text-navy">{T.takeout}</span>
              <span class="rounded-full bg-marigold/20 px-2 py-0.5 text-[0.65rem] font-bold uppercase tracking-wide text-marigold-dark">{T.badge}</span>
            </span>
            <span class="block font-body text-sm text-ink/60">{T.takeoutSub}</span>
          </span>
          <span class="text-navy/30">→</span>
        </a>

        <!-- Delivery group -->
        <p class="px-1 pt-2 font-body text-xs font-semibold uppercase tracking-wider text-ink/45">{T.deliveryLabel}</p>

        <a
          href={site.delivery.doordash}
          target="_blank"
          rel="noopener"
          class="fob-action flex items-center gap-4 rounded-2xl border border-navy-100 bg-white p-4 shadow-soft active:scale-[0.99]"
        >
          <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-[#eb1700]/10 text-[#eb1700]">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M22.5 9.7c-1-1.9-3-3.2-5.2-3.2H1.9c-.5 0-.9.4-.9.9s.4.9.9.9h3.4c.3 0 .5.1.7.3l2.2 2.2c.2.2.2.6 0 .8l-.1.1c-.2.2-.4.2-.7.2H2.5c-.5 0-.9.4-.9.9s.4.9.9.9h14.9c2.2 0 4.3-1.2 5.3-3.2.3-.6.3-1.3-.2-1.8z" />
            </svg>
          </span>
          <span class="min-w-0 flex-1">
            <span class="block font-display text-base font-bold text-navy">DoorDash</span>
            <span class="block font-body text-sm text-ink/60">{T.doordashSub}</span>
          </span>
          <span class="text-navy/30">→</span>
        </a>

        <a
          href={site.delivery.uberEats}
          target="_blank"
          rel="noopener"
          class="fob-action flex items-center gap-4 rounded-2xl border border-navy-100 bg-white p-4 shadow-soft active:scale-[0.99]"
        >
          <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-[#06c167]/10 text-[#048848]">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M4 11a8 8 0 0 1 16 0v6a3 3 0 0 1-3 3H7a3 3 0 0 1-3-3v-6z" />
              <path d="M9 11V8a3 3 0 0 1 6 0v3" />
            </svg>
          </span>
          <span class="min-w-0 flex-1">
            <span class="block font-display text-base font-bold text-navy">Uber Eats</span>
            <span class="block font-body text-sm text-ink/60">{T.uberSub}</span>
          </span>
          <span class="text-navy/30">→</span>
        </a>
      </div>
    </div>
  </div>
</div>

<script>
  (function () {
    const root = document.getElementById('fob-root');
    const btn = document.getElementById('fob-btn');
    const backdrop = document.getElementById('fob-backdrop');
    const panel = document.getElementById('fob-panel');
    const closeBtn = document.getElementById('fob-close');
    if (!root || !btn || !backdrop || !panel) return;

    let isOpen = false;

    function open() {
      isOpen = true;
      backdrop.classList.remove('opacity-0', 'pointer-events-none');
      backdrop.classList.add('opacity-100', 'pointer-events-auto');
      panel.classList.remove('translate-y-full');
      panel.classList.add('translate-y-0');
      btn.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
      closeBtn?.focus();
    }

    function close() {
      isOpen = false;
      backdrop.classList.add('opacity-0', 'pointer-events-none');
      backdrop.classList.remove('opacity-100', 'pointer-events-auto');
      panel.classList.add('translate-y-full');
      panel.classList.remove('translate-y-0');
      btn.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
      btn.focus();
    }

    btn.addEventListener('click', () => (isOpen ? close() : open()));
    closeBtn?.addEventListener('click', close);
    backdrop.addEventListener('click', close);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen) close();
    });
    // Tapping any action closes the sheet (link still navigates)
    panel.querySelectorAll('.fob-action').forEach((a) => a.addEventListener('click', close));

    // Hide the whole floating flow while the mobile nav drawer is open,
    // so the two don't overlap on small screens.
    const drawer = document.getElementById('mobile-menu');
    if (drawer) {
      const sync = () => {
        const menuOpen = !drawer.classList.contains('hidden');
        root.style.display = menuOpen ? 'none' : '';
        if (menuOpen && isOpen) close();
      };
      new MutationObserver(sync).observe(drawer, { attributes: true, attributeFilter: ['class'] });
    }
  })();
</script>
